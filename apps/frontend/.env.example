# Copia a .env.local (no commitear)
DATABASE_URL=postgresql://USUARIO:CONTRASEÑA@HOST-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://USUARIO:CONTRASEÑA@HOST.region.aws.neon.tech/neondb?sslmode=require

# Obligatoria en Vercel; en local puedes omitirla (se usa un valor solo desarrollo)
SESSION_SECRET=

# Opcional: usuarios extra o sustitución de claves sin tocar código (JSON en una sola línea)
